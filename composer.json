{
    "name": "survos/imgproxy-bundle",
    "description": "Symfony bundle for signing and generating imgproxy URLs",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "imgproxy", "image", "resize", "thumbnail"],
    "autoload": {
        "psr-4": {
            "Survos\\ImgproxyBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\ImgproxyBundle\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "symfony/config": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/http-kernel": "^8.0",
        "twig/twig": "^3.14"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "symfony/framework-bundle": "^8.0"
    },
    "extra": {
        "symfony": {
            "require": "^8.0"
        }
    }
}
